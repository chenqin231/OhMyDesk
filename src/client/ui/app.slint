// OhMyDesk 客户端 Slint UI —— 参考 v0「AI-Remote Sentinel」设计重做（信创软渲染，无 GPU）。
//
// 设计来源：v0_client（Sentinel 桌面远控客户端原型）。软渲染无 backdrop-blur，玻璃拟态用
// 半透明实色层近似；不引入 std-widgets（其默认浅色样式与深色主题冲突），全用内置元素 +
// 自定义控件，保证深色 token 完全可控。
//
// 单窗口承载多态：
//   1. 空闲态：居中 420 卡片（Header + 设备卡 + 连接卡 + 最近连接）。
//   2. 被控提示条（being_controlled 时顶部常驻）。
//   3. 连接中遮罩（connecting，主控等待对端授权）。
//   4. 授权弹窗（auth_pending）。
//   5. 主控画面态（remote_active：贴帧铺满 + 悬浮工具条 + 键鼠捕获）。
//
// 跨线程更新约束：网络/解码线程禁止直接 set_xxx，一律 invoke_from_event_loop + Weak（见 main.rs）。

// ── 深色 token（对齐 v0 globals.css .dark 色板）──
global Theme {
    out property <color> bg: #0a0a0b;            // 深空背景
    out property <color> card: #131316;          // 卡片
    out property <color> card-border: #ffffff14; // 卡片描边（白 8%）
    out property <color> inset: #ffffff0a;        // 内嵌输入/值框底
    out property <color> muted: #18181b;          // 次级面
    out property <color> fg: #f4f4f5;             // 主文本
    out property <color> fg-muted: #9b9ba3;       // 次级文本
    out property <color> primary: #3b82f6;        // 主蓝
    out property <color> primary-hover: #5b9bff;
    out property <color> emerald: #10b981;        // 在线绿
    out property <color> danger: #ef4444;         // 告警红
    out property <color> danger-hover: #f15a5a;
    out property <color> amber: #f0b86e;          // 被控提示
}

// 一条最近连接（Rust 侧 build 后 set_history）。
struct HistoryItem {
    raw_id: string,   // 纯数字 id（回填 target_id 用）
    label: string,    // 分组展示 "419 027 558"
    sub: string,      // 相对时间 "2 分钟前"
}

// 一个目录条目（与 protocol::FileEntry 同形：Rust 侧 build 后 set_*_entries）。
struct FileEntry {
    name: string,
    is_dir: bool,
    size: int,    // 字节（u64 在 Slint 用 int 承载，仅展示用，超 2^31 极少见）
}

// 路径父/子计算下沉到 Rust：Slint 字符串能力弱（无 split/rsplit），故只产出带标记的指令串
// （"<up>:当前路径" / "<cd>:当前路径|子名"），由 ui_glue 用 PathBuf 精确算父/子再 list（见 Task 9）。
// 放 global 让 FilePane（AppWindow 外的组件）也能调用。
global PathUtil {
    // 上级目录：产出 "<up>:当前路径" 指令串（空/根返回空串=回 home/盘符列表）。
    pure public function parent_path(p: string) -> string {
        if (p == "" || p == "/") {
            return "";
        }
        return "<up>:" + p;
    }
    // 子目录：产出 "<cd>:当前路径|子名" 指令串。
    pure public function child_path(p: string, name: string) -> string {
        return "<cd>:" + p + "|" + name;
    }
}

// ── 通用控件 ───────────────────────────────────────────────

// 卡片容器
component Card inherits Rectangle {
    border-radius: 14px;
    background: Theme.card;
    border-width: 1px;
    border-color: Theme.card-border;
}

// 区段小标题（圆点 + 文字）
component SectionHeader inherits HorizontalLayout {
    in property <string> label;
    in property <color> dot: Theme.emerald;
    spacing: 8px;
    // 圆点用 VerticalLayout 居中：HorizontalLayout 跨轴不会自动垂直居中固定高度子元素，
    // 直接放会与文字基线错位（issue#2）。
    VerticalLayout {
        alignment: center;
        Rectangle {
            width: 6px;
            height: 6px;
            border-radius: 3px;
            background: root.dot;
        }
    }
    Text {
        text: root.label;
        color: Theme.fg-muted;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 1.5px;
        vertical-alignment: center;
    }
    Rectangle { } // 右侧留白撑开
}

// 幽灵小按钮（复制 / 换）
component GhostButton inherits Rectangle {
    in property <string> label;
    callback clicked;
    border-radius: 6px;
    background: ta.has-hover ? #ffffff14 : transparent;
    animate background { duration: 120ms; }
    HorizontalLayout {
        padding-left: 9px;
        padding-right: 9px;
        padding-top: 5px;
        padding-bottom: 5px;
        Text {
            text: root.label;
            color: ta.has-hover ? Theme.fg : Theme.fg-muted;
            font-size: 12px;
            vertical-alignment: center;
        }
    }
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

// 主操作按钮
component PrimaryButton inherits Rectangle {
    in property <string> label;
    in property <bool> enabled: true;
    callback clicked;
    height: 42px;
    border-radius: 9px;
    background: !root.enabled ? #25303f
        : (ta.has-hover ? Theme.primary-hover : Theme.primary);
    animate background { duration: 120ms; }
    Text {
        text: root.label;
        color: root.enabled ? white : Theme.fg-muted;
        font-size: 15px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    ta := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => {
            root.clicked();
        }
    }
}

// 危险按钮（断开）
component DangerButton inherits Rectangle {
    in property <string> label;
    callback clicked;
    height: 30px;
    border-radius: 8px;
    background: ta.has-hover ? Theme.danger-hover : Theme.danger;
    animate background { duration: 120ms; }
    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        Text {
            text: root.label;
            color: white;
            font-size: 13px;
            font-weight: 600;
            vertical-alignment: center;
        }
    }
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

// 带占位符的输入框（自定义，避开 std-widgets 浅色样式）
component FieldInput inherits Rectangle {
    in property <string> placeholder;
    in-out property <string> text;
    in property <bool> password: false;
    callback accepted;
    height: 44px;
    border-radius: 9px;
    background: Theme.inset;
    border-width: 1px;
    border-color: ti.has-focus ? Theme.primary : Theme.card-border;
    animate border-color { duration: 120ms; }
    HorizontalLayout {
        padding-left: 13px;
        padding-right: 13px;
        ti := TextInput {
            text <=> root.text;
            color: Theme.fg;
            font-size: 15px;
            font-family: "monospace";
            letter-spacing: 1px;
            vertical-alignment: center;
            single-line: true;
            input-type: root.password ? InputType.password : InputType.text;
            accepted => {
                root.accepted();
            }
        }
    }
    // 占位符：空文本时显示，非交互（点击穿透到 TextInput）
    if root.text == "": Text {
        x: 13px;
        height: 100%;
        text: root.placeholder;
        color: Theme.fg-muted;
        font-size: 15px;
        vertical-alignment: center;
    }
}

// 一行「值框」：小标题 + 大号等宽值 + 右侧动作
component ValueRow inherits Rectangle {
    in property <string> caption;
    in property <string> value;
    in property <color> value-color: Theme.fg;
    in property <bool> masked: false;
    border-radius: 10px;
    background: Theme.inset;
    border-width: 1px;
    border-color: Theme.card-border;
    VerticalLayout {
        padding: 12px;
        spacing: 3px;
        Text {
            text: root.caption;
            color: Theme.fg-muted;
            font-size: 11px;
        }
        HorizontalLayout {
            spacing: 8px;
            Text {
                text: root.masked ? "••••••" : root.value;
                color: root.value-color;
                font-size: 24px;
                font-weight: 700;
                font-family: "monospace";
                letter-spacing: 3px;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
            @children // 右侧动作按钮
        }
    }
}

// 一条最近连接行
component HistoryRow inherits Rectangle {
    in property <string> label;
    in property <string> sub;
    in property <string> raw;
    callback chosen(string);
    height: 50px;
    border-radius: 10px;
    background: ta.has-hover ? #ffffff0a : transparent;
    animate background { duration: 120ms; }
    HorizontalLayout {
        padding: 8px;
        spacing: 11px;
        Rectangle {
            width: 34px;
            height: 34px;
            border-radius: 9px;
            background: Theme.muted;
            border-width: 1px;
            border-color: Theme.card-border;
            Text {
                text: "›_";
                color: Theme.fg-muted;
                font-size: 13px;
                font-family: "monospace";
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
        VerticalLayout {
            alignment: center;
            spacing: 2px;
            Text {
                text: root.label;
                color: Theme.fg;
                font-size: 13px;
                font-weight: 500;
                font-family: "monospace";
                letter-spacing: 1px;
            }
            Text {
                text: root.sub;
                color: Theme.fg-muted;
                font-size: 11px;
            }
        }
        Rectangle { }
    }
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.chosen(root.raw);
        }
    }
}

// 行内操作按钮（下发/取回）——描边 + 主色文字，比 GhostButton 更显眼，提升可发现性。
component RowActionButton inherits Rectangle {
    in property <string> label;
    callback clicked;
    width: 68px;
    height: 24px;
    border-radius: 6px;
    background: ta.has-hover ? #3b82f640 : #3b82f61f;
    border-width: 1px;
    border-color: #3b82f566;
    animate background { duration: 120ms; }
    Text {
        text: root.label;
        color: Theme.primary-hover;
        font-size: 11px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

// 文件浏览单栏：标题 + 路径行（含上级/刷新）+ 条目列表 + 操作（下发/取回）。
// 路径父/子计算下沉到 Rust：open_dir 回调收到 "<up>:"/"<cd>:" 指令串，ui_glue 解析后列目录。
// 交互（强化点击式）：
//   - 名称区与操作按钮各自独立、互不重叠的 TouchArea —— 杜绝「全行 TouchArea 罩在按钮上、
//     按钮永不触发」的 z-order 陷阱（取回/下发点了没反应的根因）。
//   - 名称区点击：目录→进入，文件→选中高亮（视觉反馈）。
//   - 操作按钮：文件与目录都显示；目录即「整个文件夹」一并传输。
component FilePane inherits Rectangle {
    in property <string> title;
    in property <string> path;
    in property <[FileEntry]> entries;
    in property <string> action_label;          // "下发→" 或 "←取回"
    in-out property <string> selected_name;      // 当前选中文件名（高亮反馈；进目录/刷新即清空）
    callback open_dir(string /*path*/);          // 进入子目录/上级
    callback refresh();
    callback act(string /*entry_name*/);         // 对选中文件/文件夹执行下发/取回
    border-radius: 10px;
    background: #0d0d10;
    border-width: 1px;
    border-color: Theme.card-border;
    VerticalLayout {
        padding: 10px;
        spacing: 8px;
        Text {
            text: root.title;
            color: Theme.fg-muted;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 1px;
        }
        // 路径行
        HorizontalLayout {
            spacing: 6px;
            Text {
                text: root.path == "" ? "/" : root.path;
                color: Theme.fg;
                font-size: 12px;
                font-family: "monospace";
                vertical-alignment: center;
                horizontal-stretch: 1;
                overflow: elide;
            }
            GhostButton {
                label: "上级";
                clicked => {
                    root.selected_name = "";
                    root.open_dir(PathUtil.parent_path(root.path));
                }
            }
            GhostButton {
                label: "刷新";
                clicked => {
                    root.refresh();
                }
            }
        }
        // 条目列表
        Rectangle {
            vertical-stretch: 1;
            Flickable {
                width: 100%;
                height: 100%;
                viewport-width: self.width;
                viewport-height: list_col.preferred-height;
                list_col := VerticalLayout {
                    spacing: 1px;
                    if root.entries.length == 0: Text {
                        text: "（空目录或加载中）";
                        color: Theme.fg-muted;
                        font-size: 12px;
                    }
                    for e in root.entries: Rectangle {
                        height: 34px;
                        border-radius: 6px;
                        background: (e.name == root.selected_name && !e.is_dir)
                            ? #3b82f626
                            : (name_ta.has-hover ? #ffffff0a : transparent);
                        animate background { duration: 100ms; }
                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 8px;
                            spacing: 8px;
                            // 名称区（独立 TouchArea，仅覆盖名称区域，不与按钮重叠）
                            Rectangle {
                                horizontal-stretch: 1;
                                HorizontalLayout {
                                    spacing: 8px;
                                    Text {
                                        text: e.is_dir ? "[目录]" : "[文件]";
                                        color: e.is_dir ? Theme.primary : Theme.fg-muted;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: e.name;
                                        color: Theme.fg;
                                        font-size: 13px;
                                        font-family: "monospace";
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                        overflow: elide;
                                    }
                                }
                                name_ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        // 目录→进入（清选中）；文件→选中高亮
                                        if (e.is_dir) {
                                            root.selected_name = "";
                                            root.open_dir(PathUtil.child_path(root.path, e.name));
                                        } else {
                                            root.selected_name = e.name;
                                        }
                                    }
                                }
                            }
                            // 操作按钮（文件与目录都显示；目录=整个文件夹）——独立区域，点击必触发
                            VerticalLayout {
                                alignment: center;
                                RowActionButton {
                                    label: root.action_label;
                                    clicked => {
                                        root.selected_name = e.name;
                                        root.act(e.name);
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

// ── 主窗口 ─────────────────────────────────────────────────
export component AppWindow inherits Window {
    title: "OhMyDesk 客户端";
    icon: @image-url("../icons/app-icon.png");
    // 默认紧凑小窗（贴合原型卡片）；进入主控画面态由 Rust 动态放大到 ~1280×820。
    preferred-width: 460px;
    preferred-height: 620px;
    min-width: 420px;
    min-height: 520px;
    background: Theme.bg;
    default-font-size: 14px;

    // ── 被控端状态 ──
    in property <string> self_id;                 // 本机注册 id（已分组展示）
    in property <string> self_password;           // 本机临时密码（展示给授权用）
    in-out property <bool> password_visible: false;  // 临时密码是否明文显示(眼睛切换)
    in property <bool> connected: false;          // 是否已连上服务器（Header 在线灯）
    in property <bool> being_controlled: false;   // 是否正在被远程
    in property <string> peer_name;               // 控制方名称（提示条用）

    // 授权弹窗
    in property <bool> auth_pending: false;
    in property <string> auth_requester;
    in property <string> auth_source;
    in-out property <int> auth_countdown: 60;
    in property <bool> controlled_forced: false;
    callback auth_accept();
    callback auth_reject();
    callback stop_being_controlled();

    // 被控端聊天面板（被控期间真人可回复）
    in-out property <bool> chat_panel_open: false;    // 面板展开
    in-out property <bool> controlled_chat_unread: false; // 被控聊天入口红点
    in-out property <string> controlled_chat_log;     // 被控侧聊天记录累积
    in-out property <string> controlled_chat_input;   // 被控侧输入
    callback send_controlled_chat(string /*text*/);   // 被控发送（复用 SendChat，session=被控会话）
    // 被控端右下角新消息弹卡：对端发来且聊天面板未打开时弹出，醒目提醒（修复消息藏在顶部看不到）
    in-out property <bool> controlled_toast_visible: false;
    in property <string> controlled_toast_text;       // 弹卡内最新消息预览（Rust 侧 set）

    // ── 主控端状态（模式 B：client→client 发起）──
    in property <bool> remote_active: false;      // 已进入主控画面态
    in-out property <bool> connecting: false;     // 发起后等待对端授权（遮罩）；Slint try-start 也写它
    in-out property <bool> awaiting_consent: false;   // 无密码申请:等待对方同意态
    in-out property <int> consent_countdown: 60;
    callback cancel_remote();
    in-out property <string> target_id;
    in-out property <string> target_password;
    in-out property <string> remote_status;        // 失败提示（"密码错误"等）
    in-out property <image> frame;
    in property <int> frame_w: 1;
    in property <int> frame_h: 1;
    callback connect_b();
    callback disconnect_remote();
    in-out property <bool> high_quality: false;   // 画质档位：true=高清优先，false=流畅优先
    callback set_quality(bool /*high*/);          // 主控切换画质档位

    // ── 主控工作台标签（0=远程桌面 1=远程命令 2=远程文件 3=即时消息）──
    in-out property <int> active_tab: 0;
    in-out property <bool> chat_unread: false;       // 即时消息标签未读红点
    callback tab_changed(int /*tab*/);               // 切标签 → Rust 侧发 SetCapture（懒推流）

    // ── 远程命令 ──
    in-out property <string> cmd_input;              // 命令输入行
    in property <string> cmd_output;                 // 输出区累积文本（Rust 侧 append）
    callback run_command(string /*command*/);        // 执行命令

    // ── 远程文件 ──
    in property <[FileEntry]> local_entries: [];     // 左栏本机目录条目
    in property <string> local_path;                 // 左栏当前本机绝对路径
    in property <[FileEntry]> remote_entries: [];    // 右栏远端目录条目
    in property <string> remote_path;                // 右栏当前远端绝对路径
    in property <string> file_notice;                // 传输状态行
    callback list_local(string /*path*/);            // 浏览本机目录
    callback list_remote(string /*path*/);           // 浏览远端目录
    callback push_file(string /*local_name*/);       // 下发左栏选中文件到右栏当前目录
    callback pull_file(string /*remote_name*/);      // 取回右栏选中文件到左栏当前目录

    // ── 即时消息 ──
    in property <string> chat_log;                   // 聊天记录累积文本（Rust 侧 append）
    in-out property <string> chat_input;             // 输入行
    callback send_chat(string /*text*/);             // 发送消息

    // 设备卡动作
    callback copy_text(string);                   // 复制 ID/密码到剪贴板
    callback refresh_password();                  // 刷新临时密码

    // 自动更新横幅
    in property <bool> update_available: false;
    in property <string> update_version;
    in property <string> update_url;
    in property <string> update_notes;
    callback copy_url(string);                    // 复制下载链接（不过滤空白）

    // ── 隐藏诊断菜单 ──
    in property <string> diag_dir;                   // 诊断包目录（Rust 启动时 set）
    in-out property <bool> diag_visible: false;      // 诊断面板可见
    in-out property <int> diag_taps: 0;              // Header logo 连点计数（≥5 开面板）
    callback set_render_mode(string);                // 切运行模式（legacy-full-frame/frameskip…）
    callback export_diag();                          // 导出诊断包（发 ExportNow）
    callback copy_diag_path();                       // 复制诊断目录路径到剪贴板

    // 最近连接
    in property <[HistoryItem]> history: [];

    // 主控画面区键鼠回调（坐标已换算为帧内像素）
    callback on_pointer_move(int /*x*/, int /*y*/);
    callback on_pointer_button(int /*x*/, int /*y*/, int /*btn 0左1中2右*/, bool /*down*/);
    callback on_key(string /*code*/, bool /*down*/);

    // Slint 把修饰键（Ctrl/Shift/Alt/Meta）的 ev.text 给成特殊控制字符，被控端无法识别为修饰键，
    // 导致组合键（Ctrl+C/V）的修饰态不被跟踪。这里把修饰键归一成被控端认得的名字串；
    // 其余按键（字母/数字/Enter/Backspace 等控制符）原样透传，被控端 code_to_key 已能处理。
    pure function key_code(t: string) -> string {
        return (t == Key.Control || t == Key.ControlR) ? "Control"
            : (t == Key.Shift || t == Key.ShiftR) ? "Shift"
            : (t == Key.Alt || t == Key.AltGr) ? "Alt"
            : (t == Key.Meta || t == Key.MetaR) ? "Meta"
            : t;
    }

    // ① 空闲态：被控提示条 + 居中卡片
    if !root.remote_active: VerticalLayout {
        // 更新横幅（常驻顶部，仅发现新版时显示）
        if root.update_available: Rectangle {
            height: root.update_notes != "" ? 62px : 46px;
            background: Theme.primary;
            HorizontalLayout {
                padding-left: 14px; padding-right: 14px; spacing: 10px;
                VerticalLayout {
                    alignment: center; spacing: 2px;
                    Text {
                        vertical-alignment: center; horizontal-alignment: left;
                        color: white; font-size: 13px;
                        text: "发现新版 v" + root.update_version + "，建议更新";
                    }
                    if root.update_notes != "": Text {
                        vertical-alignment: center; horizontal-alignment: left;
                        color: #ffffffb3; font-size: 11px;
                        text: root.update_notes;
                    }
                }
                Rectangle { horizontal-stretch: 1; }
                GhostButton {
                    label: "复制下载链接";
                    clicked => { root.copy_url(root.update_url); }
                }
            }
        }
        // 被控提示条（常驻顶部，仅 being_controlled 时显示）
        if root.being_controlled: Rectangle {
            height: 42px;
            background: root.controlled_forced ? #2a1416 : #211a0d;
            border-width: 1px;
            border-color: root.controlled_forced ? Theme.danger : #4a3a18;
            HorizontalLayout {
                alignment: center;
                spacing: 8px;
                VerticalLayout {
                    alignment: center;
                    Rectangle {
                        width: 7px;
                        height: 7px;
                        border-radius: 4px;
                        background: root.controlled_forced ? Theme.danger : Theme.amber;
                    }
                }
                Text {
                    text: root.controlled_forced
                        ? "管理员正在强制远程控制本机"
                        : "此设备正在被 " + root.peer_name + " 远程控制";
                    color: root.controlled_forced ? Theme.danger : Theme.amber;
                    font-size: 13px;
                    font-weight: 500;
                    vertical-alignment: center;
                }
                GhostButton {
                    label: root.controlled_chat_unread ? "聊天 ●" : "聊天";
                    clicked => {
                        root.chat_panel_open = !root.chat_panel_open;
                        if (root.chat_panel_open) {
                            root.controlled_chat_unread = false;
                        }
                    }
                }
                GhostButton {
                    label: "我要断开";
                    clicked => {
                        root.stop_being_controlled();
                    }
                }
            }
        }

        // 被控端聊天紧凑面板（被控期间真人回复）
        if root.being_controlled && root.chat_panel_open: Rectangle {
            height: 220px;
            background: #131316;
            border-width: 1px;
            border-color: Theme.card-border;
            VerticalLayout {
                padding: 10px;
                spacing: 8px;
                HorizontalLayout {
                    Text {
                        text: "与 " + root.peer_name + " 的会话";
                        color: Theme.fg;
                        font-size: 13px;
                        font-weight: 600;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                    GhostButton {
                        label: "收起";
                        clicked => {
                            root.chat_panel_open = false;
                        }
                    }
                }
                Rectangle {
                    vertical-stretch: 1;
                    border-radius: 8px;
                    background: #0d0d10;
                    Flickable {
                        width: 100%;
                        height: 100%;
                        viewport-width: self.width;
                        viewport-height: cc_text.preferred-height + 16px;
                        cc_text := Text {
                            x: 10px;
                            y: 8px;
                            width: parent.width - 20px;
                            text: root.controlled_chat_log == "" ? "暂无消息" : root.controlled_chat_log;
                            color: root.controlled_chat_log == "" ? Theme.fg-muted : Theme.fg;
                            font-size: 13px;
                            wrap: word-wrap;
                        }
                    }
                }
                HorizontalLayout {
                    spacing: 8px;
                    FieldInput {
                        horizontal-stretch: 1;
                        placeholder: "回复…";
                        text <=> root.controlled_chat_input;
                        accepted => {
                            if (root.controlled_chat_input != "") {
                                root.send_controlled_chat(root.controlled_chat_input);
                                root.controlled_chat_input = "";
                            }
                        }
                    }
                    PrimaryButton {
                        label: "发送";
                        enabled: root.controlled_chat_input != "";
                        clicked => {
                            root.send_controlled_chat(root.controlled_chat_input);
                            root.controlled_chat_input = "";
                        }
                    }
                }
            }
        }

        // 卡片区（可滚动：历史变多/窗口偏小时内容不被裁切；窗口紧凑贴合原型）
        Rectangle {
            vertical-stretch: 1;
            Flickable {
                width: 100%;
                height: 100%;
                viewport-width: self.width;
                viewport-height: card-col.preferred-height;
                HorizontalLayout {
                    alignment: center;
                    card-col := VerticalLayout {
                        width: 420px;
                        padding: 10px;
                        spacing: 14px;

                        // ── Header ──
                        HorizontalLayout {
                            spacing: 10px;
                            Rectangle {
                                width: 34px;
                                height: 34px;
                                border-radius: 9px;
                                background: #3b82f626;
                                border-width: 1px;
                                border-color: #3b82f640;
                                Text {
                                    text: "S";
                                    color: Theme.primary;
                                    font-size: 18px;
                                    font-weight: 800;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                // 连点 5 次开隐藏诊断面板
                                TouchArea {
                                    clicked => {
                                        root.diag_taps += 1;
                                        if (root.diag_taps >= 5) {
                                            root.diag_visible = true;
                                            root.diag_taps = 0;
                                        }
                                    }
                                }
                            }
                        }

                        // ── 设备卡（本机 ID + 临时密码）──
                        Card {
                            VerticalLayout {
                                padding: 16px;
                                spacing: 12px;
                                SectionHeader {
                                    label: "您的设备";
                                    dot: Theme.emerald;
                                }
                                ValueRow {
                                    caption: "本机 ID";
                                    value: root.self_id;
                                    value-color: Theme.fg;
                                    Rectangle {
                                        property <bool> copied: false;
                                        GhostButton {
                                            label: parent.copied ? "已复制" : "复制";
                                            clicked => {
                                                root.copy_text(root.self_id);
                                                parent.copied = true;
                                            }
                                        }
                                        Timer {
                                            interval: 0.8s;
                                            running: parent.copied;
                                            triggered => { parent.copied = false; }
                                        }
                                    }
                                }
                                ValueRow {
                                    caption: "临时密码";
                                    value: root.self_password;
                                    value-color: Theme.emerald;
                                    masked: !root.password_visible;
                                    // 用中文文字替代几何符号图标：◉○↻⧉✓ 不在打包字体内，
                                    // Ubuntu/Windows 软渲染显示为豆腐块（issue#3）。
                                    GhostButton {
                                        label: root.password_visible ? "隐藏" : "显示";
                                        clicked => {
                                            root.password_visible = !root.password_visible;
                                        }
                                    }
                                    GhostButton {
                                        label: "刷新";
                                        clicked => {
                                            root.refresh_password();
                                        }
                                    }
                                    Rectangle {
                                        property <bool> copied: false;
                                        GhostButton {
                                            label: parent.copied ? "已复制" : "复制";
                                            clicked => {
                                                root.copy_text(root.self_password);
                                                parent.copied = true;
                                            }
                                        }
                                        Timer {
                                            interval: 0.8s;
                                            running: parent.copied;
                                            triggered => { parent.copied = false; }
                                        }
                                    }
                                }
                            }
                        }

                        // ── 连接卡（发起远控）──
                        Card {
                            VerticalLayout {
                                padding: 16px;
                                spacing: 10px;
                                SectionHeader {
                                    label: "连接到伙伴";
                                    dot: Theme.primary;
                                }
                                FieldInput {
                                    placeholder: "伙伴 ID";
                                    text <=> root.target_id;
                                    accepted => {
                                        root.try-start();
                                    }
                                }
                                FieldInput {
                                    placeholder: "密码";
                                    password: true;
                                    text <=> root.target_password;
                                    accepted => {
                                        root.try-start();
                                    }
                                }
                                PrimaryButton {
                                    label: "开始控制";
                                    enabled: root.target_id != "";
                                    clicked => {
                                        root.try-start();
                                    }
                                }
                                if root.remote_status != "": Text {
                                    text: root.remote_status;
                                    color: Theme.danger;
                                    font-size: 12px;
                                }
                            }
                        }

                        // ── 最近连接 ──
                        VerticalLayout {
                            padding-left: 4px;
                            padding-right: 4px;
                            spacing: 2px;
                            Text {
                                text: "最近连接";
                                color: Theme.fg-muted;
                                font-size: 11px;
                                font-weight: 600;
                                letter-spacing: 1.5px;
                            }
                            Rectangle { height: 4px; }
                            if root.history.length == 0: Text {
                                text: "暂无最近连接记录";
                                color: Theme.fg-muted;
                                font-size: 12px;
                            }
                            for it in root.history: HistoryRow {
                                label: it.label;
                                sub: it.sub;
                                raw: it.raw_id;
                                chosen(r) => {
                                    root.target_id = r;
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // ⑤ 主控工作台：顶部 4 标签 + 整页内容（同窗同页切换）
    if root.remote_active: Rectangle {
        background: #050506;

        VerticalLayout {
            // ── 顶部标签条（含画质档位 + 断开常驻右侧）──
            Rectangle {
                height: 44px;
                background: #0b0b0ddd;
                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 10px;
                    spacing: 4px;
                    // 4 个标签
                    for tab[idx] in [
                        { t: "远程桌面", i: 0 },
                        { t: "远程命令", i: 1 },
                        { t: "远程文件", i: 2 },
                        { t: "即时消息", i: 3 },
                    ]: Rectangle {
                        width: 96px;
                        VerticalLayout {
                            alignment: center;
                            HorizontalLayout {
                                alignment: center;
                                spacing: 4px;
                                Text {
                                    text: tab.t;
                                    color: root.active_tab == tab.i ? Theme.fg : Theme.fg-muted;
                                    font-size: 13px;
                                    font-weight: root.active_tab == tab.i ? 700 : 500;
                                    vertical-alignment: center;
                                }
                                // 即时消息未读红点
                                if tab.i == 3 && root.chat_unread: Rectangle {
                                    width: 7px;
                                    height: 7px;
                                    border-radius: 4px;
                                    background: Theme.danger;
                                }
                            }
                            // 选中下划线
                            Rectangle {
                                height: 2px;
                                background: root.active_tab == tab.i ? Theme.primary : transparent;
                            }
                        }
                        TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.active_tab = tab.i;
                                if (tab.i == 3) { root.chat_unread = false; }
                                root.tab_changed(tab.i);
                            }
                        }
                    }
                    Rectangle { } // 撑开
                    // 画质档位切换（仅远程桌面标签有意义，常驻方便随时切）
                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width: 132px;
                            height: 28px;
                            border-radius: 8px;
                            background: #1a1a1edd;
                            HorizontalLayout {
                                padding: 2px;
                                spacing: 2px;
                                Rectangle {
                                    border-radius: 6px;
                                    background: !root.high_quality ? Theme.emerald : transparent;
                                    Text {
                                        text: "流畅";
                                        color: white;
                                        font-size: 11px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                    TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => {
                                            root.high_quality = false;
                                            root.set_quality(false);
                                        }
                                    }
                                }
                                Rectangle {
                                    border-radius: 6px;
                                    background: root.high_quality ? Theme.emerald : transparent;
                                    Text {
                                        text: "高清";
                                        color: white;
                                        font-size: 11px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                    TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => {
                                            root.high_quality = true;
                                            root.set_quality(true);
                                        }
                                    }
                                }
                            }
                        }
                    }
                    // 断开（常驻标签条右侧）
                    VerticalLayout {
                        alignment: center;
                        DangerButton {
                            label: "断开";
                            clicked => {
                                root.disconnect_remote();
                            }
                        }
                    }
                }
            }

            // ── 内容区 ──
            Rectangle {
                vertical-stretch: 1;

                // tab 0：远程桌面（贴帧 + 键鼠捕获，键鼠只在此 if 内渲染，天然门控）
                if root.active_tab == 0: Rectangle {
                    background: #050506;
                    // 进入主控画面即把焦点交给键盘 FocusScope；否则它永不获焦、key-pressed 不触发、
                    // 主控端一个 Input::Key 都不发 → 表现为「画面正常但任何键都输不进去」。
                    init => { fs.focus(); }
                    property <float> frame_scale: root.frame_w <= 1 || root.frame_h <= 1 ? 1 : (
                        (self.width / (root.frame_w * 1px)) < (self.height / (root.frame_h * 1px))
                            ? ((self.width / (root.frame_w * 1px)) < 1 ? (self.width / (root.frame_w * 1px)) : 1)
                            : ((self.height / (root.frame_h * 1px)) < 1 ? (self.height / (root.frame_h * 1px)) : 1));
                    property <length> frame_display_w: root.frame_w <= 1 ? self.width : (root.frame_w * 1px * self.frame_scale);
                    property <length> frame_display_h: root.frame_h <= 1 ? self.height : (root.frame_h * 1px * self.frame_scale);
                    property <length> frame_display_x: (self.width - self.frame_display_w) / 2;
                    property <length> frame_display_y: (self.height - self.frame_display_h) / 2;

                    // 首帧到达前的占位（frame_w 默认 1）
                    if root.frame_w <= 1: VerticalLayout {
                        alignment: center;
                        HorizontalLayout {
                            alignment: center;
                            VerticalLayout {
                                alignment: center;
                                spacing: 10px;
                                HorizontalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 52px;
                                        height: 52px;
                                        border-radius: 26px;
                                        background: Theme.muted;
                                        border-width: 1px;
                                        border-color: Theme.card-border;
                                        Text {
                                            text: "▣";
                                            color: Theme.fg-muted;
                                            font-size: 20px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                                Text {
                                    text: "远程桌面已就绪";
                                    color: Theme.fg;
                                    font-size: 14px;
                                    font-weight: 500;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "正在接收对端画面…";
                                    color: Theme.fg-muted;
                                    font-size: 12px;
                                    horizontal-alignment: center;
                                }
                            }
                        }
                    }

                    // 贴帧
                    frame_img := Image {
                        source: root.frame;
                        image-fit: fill;
                        x: parent.frame_display_x;
                        y: parent.frame_display_y;
                        width: parent.frame_display_w;
                        height: parent.frame_display_h;
                    }

                    // 键鼠捕获（只覆盖实际画面矩形，避免 contain 黑边导致坐标偏移）
                    ta := TouchArea {
                        x: parent.frame_display_x;
                        y: parent.frame_display_y;
                        width: parent.frame_display_w;
                        height: parent.frame_display_h;
                        mouse-cursor: pointer;
                        moved => {
                            root.on_pointer_move(
                                (self.mouse-x / self.width * root.frame_w * 1px) / 1px,
                                (self.mouse-y / self.height * root.frame_h * 1px) / 1px);
                        }
                        pointer-event(ev) => {
                            if (ev.kind == PointerEventKind.down) {
                                fs.focus();  // 点画面即重新抓键盘焦点（窗口切换后兜底）
                            }
                            if (ev.kind == PointerEventKind.down || ev.kind == PointerEventKind.up) {
                                root.on_pointer_button(
                                    (self.mouse-x / self.width * root.frame_w * 1px) / 1px,
                                    (self.mouse-y / self.height * root.frame_h * 1px) / 1px,
                                    ev.button == PointerEventButton.left ? 0
                                        : ev.button == PointerEventButton.middle ? 1 : 2,
                                    ev.kind == PointerEventKind.down);
                            }
                        }
                    }

                    // 键盘焦点捕获
                    fs := FocusScope {
                        width: 0px;
                        key-pressed(ev) => {
                            root.on_key(root.key_code(ev.text), true);
                            accept
                        }
                        key-released(ev) => {
                            root.on_key(root.key_code(ev.text), false);
                            accept
                        }
                    }
                }

                // tab 1：远程命令
                if root.active_tab == 1: VerticalLayout {
                    padding: 14px;
                    spacing: 10px;
                    Text {
                        text: "远程命令（被控端 Shell 一次性执行）";
                        color: Theme.fg-muted;
                        font-size: 11px;
                        font-weight: 600;
                        letter-spacing: 1px;
                    }
                    // 输出区（可滚动累积）
                    Rectangle {
                        vertical-stretch: 1;
                        border-radius: 10px;
                        background: #0d0d10;
                        border-width: 1px;
                        border-color: Theme.card-border;
                        Flickable {
                            width: 100%;
                            height: 100%;
                            viewport-width: self.width;
                            viewport-height: out_text.preferred-height + 20px;
                            out_text := Text {
                                x: 12px;
                                y: 10px;
                                width: parent.width - 24px;
                                text: root.cmd_output == "" ? "输入命令并回车执行，如 whoami / ls / ipconfig" : root.cmd_output;
                                color: root.cmd_output == "" ? Theme.fg-muted : Theme.fg;
                                font-size: 13px;
                                font-family: "monospace";
                                wrap: word-wrap;
                            }
                        }
                    }
                    // 输入行
                    HorizontalLayout {
                        spacing: 8px;
                        FieldInput {
                            horizontal-stretch: 1;
                            placeholder: "whoami / ls / ipconfig …";
                            text <=> root.cmd_input;
                            accepted => {
                                if (root.cmd_input != "") {
                                    root.run_command(root.cmd_input);
                                    root.cmd_input = "";
                                }
                            }
                        }
                        PrimaryButton {
                            label: "执行";
                            enabled: root.cmd_input != "";
                            clicked => {
                                root.run_command(root.cmd_input);
                                root.cmd_input = "";
                            }
                        }
                    }
                }

                // tab 2：远程文件（左本机 / 右远端）
                if root.active_tab == 2: VerticalLayout {
                    padding: 14px;
                    spacing: 10px;
                    HorizontalLayout {
                        spacing: 12px;
                        FilePane {
                            horizontal-stretch: 1;
                            title: "本机（主控）";
                            path: root.local_path;
                            entries: root.local_entries;
                            action_label: "下发→";
                            open_dir(p) => {
                                root.list_local(p);
                            }
                            refresh => {
                                root.list_local(root.local_path);
                            }
                            act(name) => {
                                root.push_file(name);
                            }
                        }
                        FilePane {
                            horizontal-stretch: 1;
                            title: "远端（被控）";
                            path: root.remote_path;
                            entries: root.remote_entries;
                            action_label: "←取回";
                            open_dir(p) => {
                                root.list_remote(p);
                            }
                            refresh => {
                                root.list_remote(root.remote_path);
                            }
                            act(name) => {
                                root.pull_file(name);
                            }
                        }
                    }
                    // 传输状态行
                    if root.file_notice != "": Text {
                        text: root.file_notice;
                        color: Theme.fg-muted;
                        font-size: 12px;
                        font-family: "monospace";
                        wrap: word-wrap;
                    }
                }

                // tab 3：即时消息（主控侧整页）
                if root.active_tab == 3: VerticalLayout {
                    padding: 14px;
                    spacing: 10px;
                    // 聊天记录（可滚，自动累积）
                    Rectangle {
                        vertical-stretch: 1;
                        border-radius: 10px;
                        background: #0d0d10;
                        border-width: 1px;
                        border-color: Theme.card-border;
                        Flickable {
                            width: 100%;
                            height: 100%;
                            viewport-width: self.width;
                            viewport-height: chat_text.preferred-height + 20px;
                            chat_text := Text {
                                x: 12px;
                                y: 10px;
                                width: parent.width - 24px;
                                text: root.chat_log == "" ? "暂无消息，发送一条试试" : root.chat_log;
                                color: root.chat_log == "" ? Theme.fg-muted : Theme.fg;
                                font-size: 13px;
                                wrap: word-wrap;
                            }
                        }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        FieldInput {
                            horizontal-stretch: 1;
                            placeholder: "输入消息…";
                            text <=> root.chat_input;
                            accepted => {
                                if (root.chat_input != "") {
                                    root.send_chat(root.chat_input);
                                    root.chat_input = "";
                                }
                            }
                        }
                        PrimaryButton {
                            label: "发送";
                            enabled: root.chat_input != "";
                            clicked => {
                                root.send_chat(root.chat_input);
                                root.chat_input = "";
                            }
                        }
                    }
                }
            }
        }
    }

    // ③ 连接中遮罩（主控等待对端授权）
    if root.connecting: Rectangle {
        background: #0a0a0bdd;
        TouchArea { } // 吃掉背景点击
        VerticalLayout {
            alignment: center;
            HorizontalLayout {
                alignment: center;
                VerticalLayout {
                    alignment: center;
                    spacing: 12px;
                    HorizontalLayout {
                        alignment: center;
                        Rectangle {
                            width: 54px;
                            height: 54px;
                            border-radius: 27px;
                            background: #3b82f61f;
                            border-width: 2px;
                            border-color: #3b82f655;
                            Text {
                                text: "↻";
                                color: Theme.primary;
                                font-size: 24px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                    Text {
                        text: root.awaiting_consent
                            ? "已向 " + root.target_id + " 发送控制请求"
                            : "正在建立加密连接…";
                        color: Theme.fg;
                        font-size: 14px;
                        font-weight: 500;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: "伙伴 " + root.target_id;
                        color: Theme.fg-muted;
                        font-size: 12px;
                        font-family: "monospace";
                        horizontal-alignment: center;
                    }
                    // 进度三段（静态，软渲染不做无限动画）
                    HorizontalLayout {
                        alignment: center;
                        spacing: 6px;
                        Rectangle { width: 32px; height: 4px; border-radius: 2px; background: Theme.primary; }
                        Rectangle { width: 32px; height: 4px; border-radius: 2px; background: Theme.primary; }
                        Rectangle { width: 32px; height: 4px; border-radius: 2px; background: Theme.muted; }
                    }
                    if root.awaiting_consent: Text {
                        text: "等待对方在终端上点击同意 · " + root.consent_countdown + "s";
                        color: Theme.fg-muted;
                        font-size: 12px;
                        horizontal-alignment: center;
                    }
                    if root.awaiting_consent: PrimaryButton {
                        label: "取消请求";
                        clicked => {
                            root.awaiting_consent = false;
                            root.connecting = false;
                            root.cancel_remote();
                        }
                    }
                    Timer {
                        interval: 1s;
                        running: root.awaiting_consent;
                        triggered => {
                            if (root.consent_countdown > 1) {
                                root.consent_countdown -= 1;
                            } else {
                                root.awaiting_consent = false;
                                root.connecting = false;
                                root.remote_status = "对方未响应(60s 未同意),请求已取消";
                                root.cancel_remote();
                            }
                        }
                    }
                }
            }
        }
    }

    // ④ 授权弹窗（最顶层覆盖）
    if root.auth_pending: Rectangle {
        background: #000000bb;
        TouchArea { } // 吃掉背景点击
        VerticalLayout {
            alignment: center;
            HorizontalLayout {
                alignment: center;
                Card {
                    width: 380px;
                    background: #18181c;
                    VerticalLayout {
                        padding: 22px;
                        spacing: 8px;
                        HorizontalLayout {
                            alignment: center;
                            Rectangle {
                                width: 44px;
                                height: 44px;
                                border-radius: 22px;
                                background: #3b82f61f;
                                border-width: 1px;
                                border-color: #3b82f655;
                                Text {
                                    text: "?";
                                    color: Theme.primary;
                                    font-size: 22px;
                                    font-weight: 800;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        Rectangle { height: 4px; }
                        Text {
                            text: "远程控制授权请求";
                            color: Theme.fg;
                            font-size: 16px;
                            font-weight: 700;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: root.auth_requester + " 请求远程控制本机";
                            color: Theme.fg-muted;
                            font-size: 13px;
                            horizontal-alignment: center;
                            wrap: word-wrap;
                        }
                        Text {
                            text: "来源：" + root.auth_source;
                            color: Theme.fg-muted;
                            font-size: 12px;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: root.auth_countdown + " 秒后自动拒绝";
                            color: Theme.amber;
                            font-size: 12px;
                            horizontal-alignment: center;
                        }
                        Timer {
                            interval: 1s;
                            running: root.auth_pending;
                            triggered => {
                                if (root.auth_countdown > 1) {
                                    root.auth_countdown -= 1;
                                } else {
                                    root.auth_reject();
                                }
                            }
                        }
                        Rectangle { height: 8px; }
                        HorizontalLayout {
                            spacing: 12px;
                            // 拒绝
                            Rectangle {
                                height: 42px;
                                horizontal-stretch: 1;
                                border-radius: 9px;
                                background: rej.has-hover ? Theme.muted : Theme.inset;
                                border-width: 1px;
                                border-color: Theme.card-border;
                                Text {
                                    text: "拒绝";
                                    color: Theme.fg;
                                    font-size: 14px;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                rej := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        root.auth_reject();
                                    }
                                }
                            }
                            // 同意
                            PrimaryButton {
                                label: "同意";
                                horizontal-stretch: 1;
                                clicked => {
                                    root.auth_accept();
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // ⑤ 隐藏诊断菜单模态（连点 Header logo 5 次触发）
    if root.diag_visible: Rectangle {
        background: #000000bb;
        TouchArea { }  // 吃背景点击
        VerticalLayout {
            alignment: center;
            HorizontalLayout {
                alignment: center;
                Card {
                    width: 420px;
                    background: #18181c;
                    VerticalLayout {
                        padding: 20px;
                        spacing: 12px;
                        SectionHeader { label: "诊断 / 渲染模式（仅排障用）"; }
                        Text { text: "当前画面异常时，可切回旧整帧画面或导出诊断包。"; color: Theme.fg-muted; wrap: word-wrap; }
                        HorizontalLayout {
                            spacing: 8px;
                            GhostButton { label: "切回旧画面"; clicked => { root.set_render_mode("legacy-full-frame"); } }
                            GhostButton { label: "默认(跳帧)"; clicked => { root.set_render_mode("frameskip"); } }
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            PrimaryButton { label: "导出诊断包"; enabled: true; clicked => { root.export_diag(); } }
                            GhostButton { label: "复制路径"; clicked => { root.copy_diag_path(); } }
                        }
                        ValueRow { caption: "诊断目录"; value: root.diag_dir; }
                        DangerButton { label: "关闭"; clicked => { root.diag_visible = false; } }
                    }
                }
            }
        }
    }

    // 被控端右下角即时消息弹卡（非模态：不吃背景点击，被控用户仍可正常操作电脑）。
    // 仅 being_controlled 且 controlled_toast_visible 时出现，醒目提醒被控用户有新消息。
    if root.being_controlled && root.controlled_toast_visible: Rectangle {
        // 占满窗口仅用于把弹卡定位到右下角；不放任何 TouchArea，避免遮挡背景交互。
        VerticalLayout {
            alignment: end;
            HorizontalLayout {
                alignment: end;
                padding: 16px;
                Rectangle {
                    width: 300px;
                    border-radius: 12px;
                    background: #1b2030f7;
                    border-width: 1px;
                    border-color: Theme.primary;
                    VerticalLayout {
                        padding: 14px;
                        spacing: 9px;
                        // 标题：圆点 + 发送方
                        HorizontalLayout {
                            spacing: 8px;
                            VerticalLayout {
                                alignment: center;
                                Rectangle {
                                    width: 8px;
                                    height: 8px;
                                    border-radius: 4px;
                                    background: Theme.primary;
                                }
                            }
                            Text {
                                text: "新消息 · " + root.peer_name;
                                color: Theme.fg;
                                font-size: 13px;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                        }
                        // 消息预览
                        Text {
                            text: root.controlled_toast_text;
                            color: Theme.fg;
                            font-size: 14px;
                            wrap: word-wrap;
                        }
                        // 操作行
                        HorizontalLayout {
                            spacing: 8px;
                            Rectangle { } // 撑开，按钮靠右
                            GhostButton {
                                label: "忽略";
                                clicked => {
                                    root.controlled_toast_visible = false;
                                }
                            }
                            Rectangle {
                                width: 72px;
                                height: 30px;
                                border-radius: 8px;
                                background: rta.has-hover ? Theme.primary-hover : Theme.primary;
                                animate background { duration: 120ms; }
                                Text {
                                    text: "回复";
                                    color: white;
                                    font-size: 13px;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                rta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        root.chat_panel_open = true;
                                        root.controlled_chat_unread = false;
                                        root.controlled_toast_visible = false;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        // 10s 自动收起（顶部「聊天 ●」红点仍在，用户可再打开），避免长期遮挡。
        Timer {
            interval: 10s;
            running: root.controlled_toast_visible;
            triggered => {
                root.controlled_toast_visible = false;
            }
        }
    }

    // 发起远控：校验非空 → 置连接中 → 触发回调（Slint 内联，避免空请求）
    function try-start() {
        if (root.target_id != "") {
            root.connecting = true;
            root.connect_b();
        }
    }
}
